SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=turicum-documents
# Server-side source of truth. Use root mount with "/" or leave blank.
TURICUM_BASE_PATH=/turicum
APP_ORIGIN=https://marketshift.net
# Public fallbacks for client-side path/origin reads only.
NEXT_PUBLIC_BASE_PATH=/turicum
NEXT_PUBLIC_APP_ORIGIN=https://marketshift.net
TURICUM_LEGAL_ANALYSIS_PATH=./data/turicum-legal-analysis-latest.json
TURICUM_LEGAL_CORPUS_CONFIG=./config/turicum-legal-corpus-sources.json
