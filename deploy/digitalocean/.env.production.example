NODE_ENV=production
PORT=3100
TURICUM_BASE_PATH=
NEXT_PUBLIC_BASE_PATH=
APP_ORIGIN=https://turicum.us
NEXT_PUBLIC_APP_ORIGIN=https://turicum.us
TURICUM_LEGAL_ANALYSIS_PATH=./data/turicum-legal-analysis-latest.json
TURICUM_LEGAL_CORPUS_CONFIG=./config/turicum-legal-corpus-sources.json

# Team workspace gate
TURICUM_TEAM_EMAIL=team@turicum.us
TURICUM_TEAM_PASSWORD=replace-me
TURICUM_TEAM_EMAIL_2=ops@turicum.us
TURICUM_TEAM_PASSWORD_2=replace-me
TURICUM_TEAM_SESSION_SECRET=replace-me-with-a-long-random-value

# Investor review portal seed for first production setup
TURICUM_INVESTOR_REVIEW_EMAIL=investor@turicum.us
TURICUM_INVESTOR_REVIEW_PASSWORD=replace-me

# Optional: enable shared workflow persistence
