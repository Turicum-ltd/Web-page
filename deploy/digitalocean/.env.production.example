NODE_ENV=production
PORT=3100
ATLAS_BASE_PATH=/atlas
NEXT_PUBLIC_BASE_PATH=/atlas
APP_ORIGIN=https://marketshift.net
NEXT_PUBLIC_APP_ORIGIN=https://marketshift.net
ATLAS_LEGAL_ANALYSIS_PATH=./data/atlas-legal-analysis-latest.json
ATLAS_LEGAL_CORPUS_CONFIG=./config/atlas-legal-corpus-sources.json

# Team workspace gate
TURICUM_TEAM_EMAIL=team@turicum.us
TURICUM_TEAM_PASSWORD=replace-me
TURICUM_TEAM_EMAIL_2=ops@turicum.us
TURICUM_TEAM_PASSWORD_2=replace-me
TURICUM_TEAM_SESSION_SECRET=replace-me-with-a-long-random-value

# Investor review portal seed for first production setup
TURICUM_INVESTOR_REVIEW_EMAIL=investor@turicumllc.com
TURICUM_INVESTOR_REVIEW_PASSWORD=replace-me

