{
  "name": "turicum-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "rm -rf .next/types && next typegen && ./node_modules/.bin/tsc --noEmit --incremental false",
    "dev:borrower-portal": "npm --workspace @turicum/borrower-portal run dev",
    "build:borrower-portal": "npm --workspace @turicum/borrower-portal run build",
    "start:borrower-portal": "npm --workspace @turicum/borrower-portal run start"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "@xyflow/react": "^12.10.1",
    "next": "^15.5.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.8.3"
  }
}
